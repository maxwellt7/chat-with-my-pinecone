{
  "colors": {
    "primary": "#2563eb", "secondary": "#f59e0b",
    "background": "#ffffff", "surface": "#f8fafc",
    "text": "#1e293b", "textMuted": "#64748b", "accent": "#dc2626"
  },
  "typography": {
    "headingFont": "Georgia, serif", "bodyFont": "Inter, sans-serif",
    "h1": { "size": "48px", "weight": "700", "lineHeight": "1.2" },
    "h2": { "size": "36px", "weight": "700", "lineHeight": "1.3" },
    "h3": { "size": "24px", "weight": "600", "lineHeight": "1.4" },
    "body": { "size": "18px", "weight": "400", "lineHeight": "1.6" },
    "small": { "size": "14px", "weight": "400" }
  },
  "layout": { "maxWidth": "800px", "contentPadding": "20px", "sectionPadding": "60px 20px" },
  "borderRadius": { "small": "4px", "medium": "8px", "large": "16px" },
  "shadows": { "card": "0 2px 8px rgba(0,0,0,0.08)", "button": "none" },
  "components": {
    "ctaButton": {
      "background": "#ff6b00", "color": "#ffffff", "borderRadius": "4px",
      "padding": "16px 32px", "fontSize": "20px", "fontWeight": "700", "textTransform": "uppercase"
    },
    "testimonialCard": { "background": "#f8fafc", "borderRadius": "8px", "padding": "24px", "border": "1px solid #e2e8f0" },
    "calloutBox": { "background": "#fff7ed", "border": "2px solid #f59e0b", "borderRadius": "8px", "padding": "24px" }
  },
  "sections": ["hero", "problem", "solution", "testimonials", "guarantee", "cta", "footer"],
  "layoutPattern": "single-column"
}
